# Environment Variables
# Copy this file to .env and fill in the values

DATABASE_URL="postgresql://user:password@localhost:5432/mehmetcanwt?schema=public"
WEB_KEY="your_steam_web_api_key"
LANYARD_API_KEY="your_lanyard_api_key"
JWT_SECRET="change_this_to_a_secure_random_string"
ADMIN_PASSWORD="change_this_to_a_strong_password"
STEAM_ID="your_steam_id_64"
DISCORD_ID="your_discord_user_id"

# Optional
REDIS_URL="redis://localhost:6379"
