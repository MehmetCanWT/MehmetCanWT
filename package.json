{
  "name": "mehmetcanwt-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter \"*\" dev",
    "build": "bun --filter \"web\" build",
    "start": "NODE_ENV=production bun apps/api/src/index.ts"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}